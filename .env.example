# Proxmox VE connection
PROXMOX_HOST=https://your-proxmox-ip:8006
PROXMOX_TOKEN_ID=user@pam!dashboard
PROXMOX_TOKEN_SECRET=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Optional: add multiple Proxmox hosts (comma-separated)
# PROXMOX_HOSTS=https://pve1:8006,https://pve2:8006

# Optional: Proxmox Backup Server
# PBS_HOST=https://your-pbs-ip:8007
# PBS_TOKEN_ID=root@pam!dashboard
# PBS_TOKEN_SECRET=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Dashboard settings
PORT=2545
REFRESH_INTERVAL=30000

# Gotify notifications (optional — leave unset to disable)
# GOTIFY_URL=http://your-gotify-server
# GOTIFY_TOKEN=your-app-token
# NOTIFY_INTERVAL=60000         # How often to check for alerts (ms, default: 60s)
# NOTIFY_COOLDOWN=900000        # Min time between repeat alerts for same issue (ms, default: 15min)
# CPU_SUSTAIN_MINUTES=60        # Minutes CPU must stay above threshold before alerting (default: 60)
